APP_ENV=development
APP_PORT=8081
APP_SECRET=dev-secret-change-in-production

DATABASE_URL=postgres://relay:relay_secret@localhost:5432/relay_db?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=dev-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

ASYNQ_CONCURRENCY=10

OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317
